{
  "name": "jira2",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "productName": "BetterJira",
  "packageManager": "bun@1.3.2",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "build:desktop": "bun run build && bun run app:build:main",
    "app:icon": "node electron/resources/generate-icon.mjs",
    "start": "node .output/server/index.mjs",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "app:dev": "node scripts/dev-electron.mjs",
    "app:build:main": "tsdown",
    "app:build": "node scripts/build-desktop-artifact.mjs --platform mac --target dir --output-dir dist",
    "dist:desktop:artifact": "node scripts/build-desktop-artifact.mjs",
    "dist:desktop:dmg": "node scripts/build-desktop-artifact.mjs --platform mac --target dmg",
    "dist:desktop:dmg:arm64": "node scripts/build-desktop-artifact.mjs --platform mac --target dmg --arch arm64",
    "dist:desktop:dmg:x64": "node scripts/build-desktop-artifact.mjs --platform mac --target dmg --arch x64",
    "dist:desktop:linux": "node scripts/build-desktop-artifact.mjs --platform linux --target AppImage --arch x64",
    "dist:desktop:win": "node scripts/build-desktop-artifact.mjs --platform win --target nsis",
    "dist:desktop:win:arm64": "node scripts/build-desktop-artifact.mjs --platform win --target nsis --arch arm64",
    "dist:desktop:win:x64": "node scripts/build-desktop-artifact.mjs --platform win --target nsis --arch x64"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@tanstack/query-persist-client-core": "^5.95.2",
    "@tanstack/query-sync-storage-persister": "^5.95.2",
    "@tanstack/vue-query": "^5.66.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@tiptap/vue-3": "^3.21.0",
    "@vueuse/core": "^14.2.1",
    "nuxt": "^4.4.2",
    "openai": "^6.33.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.0.0",
    "electron": "^40.9.1",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.0",
    "tsdown": "^0.21.9",
    "typescript": "^5.7.0"
  }
}
